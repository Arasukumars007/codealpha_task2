# ============================================================
# Emotion Recognition from Speech — .gitignore
# ============================================================

# ── Python virtual environment ──────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Python cache & build artifacts ──────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Pytest cache ─────────────────────────────────────────────
.pytest_cache/
.cache/

# ── Large dataset files (download with scripts/download_data.py) ──
data/raw/ravdess/
data/raw/emodb/
data/raw/tess/

# ── Large processed feature files ────────────────────────────
data/processed/*.npz
data/processed/*.npy
data/processed/*.h5
data/processed/*.hdf5

# ── TensorBoard logs (large, regenerated by training) ────────
results/tensorboard/

# ── Jupyter Notebook checkpoints ─────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS-specific ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Temporary files ──────────────────────────────────────────
*.tmp
*.log
*.bak

# ── Secrets / credentials ────────────────────────────────────
.env
secrets.yaml
